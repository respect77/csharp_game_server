{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Debug",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.Hosting.Lifetime": "Information",
                "Microsoft.AspNetCore": "Warning",
                "System": "Warning"
            }
        }
    },
    "AllowedHosts": "*",
    "ServerSettings": {
        "ApiServer": {
            "UseApiServer": true,
            "HttpUrl": "http://localhost:8080",
            "HttpsUrl": "https://localhost:433"
        },
        "BattleServer": {
            "UseBattleServer": true,
            "Port": 7788
        },
        "MatchingServer": {
            "UseMatchingServer": true
        }
    },
    "ConnectionStrings": {
        "Redis": "localhost:6379",
        "AccountDB": "server=localhost;port=3306;database=account_db;user=root;password=1234",
        "GameDB": "server=localhost;port=3306;database=game_db;user=root;password=1234"
    },
    "DataPath": "../../../../Data/Tool/server_json",
    "MyCustomSettings": {
        "MaxConnections": 100,
        "Timeout": 30,
        "EnableLogging": true
    }
}
